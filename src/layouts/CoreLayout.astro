---
import { ClientRouter, fade, slide } from 'astro:transitions';
import '@/styles/global.css';
import CoreHeader from '@/components/ui/CoreHeader.astro';
import CoreFooter from '@/components/ui/CoreFooter.astro';

// interface Props {
//   title: string;
//   subtitle: string;
//   bgImage: string;
// }

// const { title, subtitle, bgImage } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Core Hub Plex</title>
    <meta property="og:image" content="/fijacion.webp" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body class="antialiased selection:bg-neon-pink selection:text-white">
    <CoreHeader transition:animate={fade({ duration: '.5s' })} />

    <main class="bg-dark max-w-7xl mx-auto lg:-mt-22 relative">
      <div transition:animate={slide({ duration: '1s' })}>
        <slot />
      </div>
    </main>

    <slot name="after-main-content" />

    <CoreFooter transition:animate={fade({ duration: '.5s' })} />
  </body>
</html>

<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@latest"></script>

<script>
  // Initialize Lucide Icons
  const lucide = (window as any).lucide;

  if (lucide) {
    lucide.createIcons();

    // Mobile Menu Logic
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        const icon = mobileMenu.classList.contains('hidden') ? 'menu' : 'x';
        // Re-render icon (simplified for this context)
        mobileMenuBtn.innerHTML = `<i data-lucide="${icon}" class="w-3 h-3 text-white"></i>`;
        lucide.createIcons();
      });

      // Close mobile menu on link click
      document.querySelectorAll('#mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileMenuBtn.innerHTML = `<i data-lucide="menu" class="w-3 h-3 text-white"></i>`;
          lucide.createIcons();
        });
      });
    }
  }
</script>
