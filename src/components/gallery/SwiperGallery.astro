---
import clientScript from './SwiperGalleryClient.js?url';
import { Picture } from 'astro:assets';
import { GaleriasSchema } from '@/types';
const url = `${import.meta.env.API_URL}/gallery?per_page=50`;
const res = await fetch(url);
const json = await res.json();
const data = GaleriasSchema.parse(json);
console.log(data);
---

<section class="swiper-gallery pb-15">
  <div class="mx-auto max-w-7xl">
    <div class="swiper">
      <div class="swiper-wrapper">
        {
          data.map((post) => (
            <a href={`/galerias/${post.slug}`}>
              <div class="swiper-slide relative w-full max-w-[420px] shrink-0 overflow-hidden transition-shadow bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer">
                {post?.featured_images?.medium_large?.url && (
                  <Picture
                    src={post.featured_images.medium_large.url}
                    alt={post?.title.rendered}
                    width={post?.featured_images?.medium_large?.width || 600}
                    height={post?.featured_images?.medium_large?.height || 600}
                    formats={['avif', 'webp']}
                    class="h-[28rem] w-full object-cover"
                  />
                )}
                <div class="absolute align-center text-center inset-x-0 bottom-0 bg-black/60 p-6 text-white backdrop-blur-sm">
                  <a href={`/galerias/${post.slug}`}>
                    <h2 class="mb-4 text-3xl font-semibold">
                      {post?.title.rendered}
                    </h2>
                  </a>
                  {post?.category_details?.map((cat) => (
                    <h3 class="max-w-xs inline-block py-1 px-3 text-md font-bold text-white mb-2 ml-2 mr-2 transition-neo">
                      #{cat.name}
                    </h3>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
      </div>
      <div class="swiper-pagination mt-8"></div>
      <button
        class="swiper-button-next bg-neon-cyan text-dark p-5 border-4 border-neon-cyan neo-shadow-pink neo-hover-pink transition-neo cursor-pointer"
      ></button>
      <button
        class="swiper-button-prev bg-neon-cyan text-dark p-5 border-4 border-neon-cyan neo-shadow-pink neo-hover-pink transition-neo cursor-pointer"
      ></button>
    </div>

    <script type="module" src={clientScript}></script>
  </div>
</section>
