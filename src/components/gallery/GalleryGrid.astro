---
import { Picture } from 'astro:assets';
import PostMeta from '@/components/galleries/PostMeta.astro';
import PostCategories from '@/components/galleries/PostCategories.astro';
import PostTags from '@/components/galleries/PostTags.astro';

const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;

interface Props {
  gallery: {
    directus_files_id: {
      id: string;
      filename_disk: string;
      filename_download: string;
      title?: string | null;
      type: string;
      filesize?: string;
      width?: number | null;
      height?: number | null;
    };
  }[];
  gallery_category: {
    name: string;
    slug: string;
  }[];
  gallery_tag: {
    name: string;
    slug: string;
  }[];
  author?: {
    name: string;
    slug: string;
  }[];
  excerpt: string;
  date: string;
  title: string;
}

const { gallery, excerpt, date, title, gallery_category, gallery_tag, author } =
  Astro.props;

console.log('Gallery in GalleryGrid:', gallery);
---

<article class="space-y-5 max-w-7xl mx-auto">
  <h1
    class="text-xl md:text-3xl lg:text-4xl font-black text-black dark:text-white uppercase tracking-tight"
  >
    {title}
  </h1>

  <PostMeta
    date={date}
    author={author ? author[0]?.name : ''}
    slug={author ? author[0]?.slug : ''}
  />

  <PostCategories
    name={gallery_category[0]?.name}
    slug={gallery_category[0]?.slug}
  />

  <PostTags name={gallery_tag[0]?.name} slug={gallery_tag[0]?.slug} />

  <p class="text-lg text-gray-100 mt-2">{excerpt}</p>

  <p class="text-md text-gray-400">
    *Por favor, haz click en las imágenes para verlas a tamaño completo...
  </p>

  <div id="gallery" class="columns-1 sm:columns-2 lg:columns-3 gap-5 mt-5">
    {
      gallery.map(
        (image) =>
          image?.directus_files_id?.id && (
            <a
              class="inline-block w-full mb-3 break-inside-avoid bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer"
              href={`${publicAssetsUrl}/${image.directus_files_id.id}`}
              data-pswp-width={image.directus_files_id.width}
              data-pswp-height={image.directus_files_id.height}
            >
              <Picture
                src={`${publicAssetsUrl}/${image.directus_files_id.id}`}
                alt={
                  image.directus_files_id.title ||
                  image.directus_files_id.filename_download ||
                  'Galería de imágenes'
                }
                width={image.directus_files_id.width || 600}
                height={image.directus_files_id.height || 400}
                formats={['avif', 'webp']}
              />
            </a>
          )
      )
    }
  </div>
</article>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.on('uiRegister', function () {
    if (lightbox.pswp?.ui) {
      lightbox.pswp.ui.registerElement({
        name: 'custom-caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: 'Caption text',
        onInit: (el, pswp) => {
          lightbox.pswp?.on('change', () => {
            const currSlideElement = lightbox.pswp?.currSlide?.data?.element;
            let captionHTML = '';
            if (currSlideElement) {
              const hiddenCaption = currSlideElement.querySelector(
                '.hidden-caption-content'
              );
              if (hiddenCaption) {
                // get caption from element with class hidden-caption-content
                captionHTML = hiddenCaption.innerHTML;
              } else {
                // get caption from alt attribute
                captionHTML =
                  currSlideElement.querySelector('img')?.getAttribute('alt') ??
                  '';
              }
            }
            el.innerHTML = captionHTML || '';
          });
        },
      });
    }
  });
  lightbox.init();
  document.addEventListener('astro:after-swap', function () {
    lightbox.init();
  });
</script>
