---
import { Picture } from 'astro:assets';
import type { Post } from '@/types';
import PostMeta from './PostMeta.astro';
import PostCategories from './PostCategories.astro';
import PostTags from './PostTags.astro';
interface Props {
  post: Post;
}
const { post } = Astro.props;
// console.log(post);
---

<article
  class="break-inside-avoid-column overflow-hidden transition-shadow bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer"
>
  {
    post?.featured_images?.medium_large?.url && (
      <Picture
        src={post.featured_images.medium_large.url}
        alt={post?.title.rendered}
        width={post?.featured_images?.medium_large?.width || 600}
        height={post?.featured_images?.medium_large?.height || 600}
        formats={['avif', 'webp']}
        class="w-full h-48 object-cover"
      />
    )
  }

  <div class="p-5 space-y-3">
    <h3
      class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-cyan transition-colors"
    >
      <a href={`/blog/${post.slug}`}>
        {post.title.rendered}
      </a>
    </h3>

    <PostMeta date={post.date} />

    {
      post.category_details.map((cat) => (
        <PostCategories name={cat.name} slug={cat.slug} />
      ))
    }

    {
      post?.tag_details &&
        post.tag_details.map((tag) => (
          <PostTags name={tag.name} slug={tag.slug} />
        ))
    }
  </div>
</article>
