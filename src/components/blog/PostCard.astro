---
import { Picture } from 'astro:assets';
import type { Post } from '@/types';
import PostMeta from './PostMeta.astro';
import PostCategories from './PostCategories.astro';
import PostTags from './PostTags.astro';
interface Props {
  post: Post;
}
const { post } = Astro.props;

const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;
---

<article
  class="break-inside-avoid-column overflow-hidden transition-shadow bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer"
>
  <a href={`/blog/${post.slug}`}>
    {
      post?.cover_image && (
        <Picture
          src={`${publicAssetsUrl}/${post.cover_image}`}
          alt={post?.title}
          width={800}
          height={600}
          formats={['avif', 'webp']}
          class="w-full h-48 object-cover"
        />
      )
    }

    <div class="p-5 space-y-3">
      <h3
        class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-cyan transition-colors"
      >
        {post.title}
      </h3>
    </div>

    <PostMeta
      date={post.date_created}
      author={post.author ? post.author?.name : ''}
      slug={post.author?.slug !== null ? post.author?.slug : ''}
    />

    {
      post.article_category?.name && (
        <PostCategories
          name={post.article_category.name}
          slug={post.article_category.slug}
        />
      )
    }

    {
      post?.article_tags && (
        <PostTags
          name={post.article_tags?.name}
          slug={post.article_tags?.slug}
        />
      )
    }
  </a>
</article>
