---
import { DirectusArticlesCollectionResponseSchema } from '@/types';
import PostCard from './PostCard.astro';
const newUrl = `${import.meta.env.API_ITEMS}/articles?fields=*,article_category.*,article_tags.*,author.*`;
const newRes = await fetch(newUrl);
const newJson = await newRes.json();
const newData = DirectusArticlesCollectionResponseSchema.parse(newJson);
const { data: articles } = newData;
---

<div class="columns-1 md:columns-2 lg:columns-3 gap-5 my-8 space-y-5">
  {
    articles.map(
      (post) => post.status === 'published' && <PostCard post={post} />
    )
  }
</div>
