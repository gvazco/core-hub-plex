---
import SwiperGalleryReact from './SwiperGallery';
import { DirectusGalleriesCollectionResponseSchema } from '@/types';

const url = `${import.meta.env.API_ITEMS}/galleries?fields=*,gallery_category.*,gallery_tag.*,author.*`;
const res = await fetch(url);
const json = await res.json();
const data = DirectusGalleriesCollectionResponseSchema.parse(json);
// console.log(data);
---

<section class="swiper-gallery pb-15">
  <div data-aos="zoom-out-down" class="mx-auto max-w-7xl">
    <SwiperGalleryReact client:load slides={data} />
  </div>
</section>
