---
import { Picture } from 'astro:assets';
import type { Galeria } from '@/types';
import PostMeta from './PostMeta.astro';
import PostCategories from './PostCategories.astro';
interface Props {
  post: Galeria;
}
const { post } = Astro.props;
const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;
---

<article
  class="break-inside-avoid-column overflow-hidden transition-shadow bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer"
>
  <a href={`/galerias/${post.slug}`}>
    {
      post?.cover_image && (
        <Picture
          src={`${publicAssetsUrl}/${post?.cover_image}`}
          alt={post?.title}
          width={800}
          height={600}
          formats={['avif', 'webp']}
          class="w-full h-48 object-cover"
        />
      )
    }

    <div class="p-5 space-y-3">
      <h3
        class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-cyan transition-colors"
      >
        <a href={`/galerias/${post.slug}`}>
          {post.title}
        </a>
      </h3>

      <PostMeta
        date={post.date_created}
        author={post?.author?.name}
        slug={post?.slug}
      />

      {
        (
          <PostCategories
            name={post?.gallery_category?.name}
            slug={post?.gallery_category?.slug}
          />
        )
      }
    </div>
  </a>
</article>
