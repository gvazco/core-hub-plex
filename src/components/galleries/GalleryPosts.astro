---
import { GaleriasSchema } from '@/types';
import PostCard from './PostCard.astro';
const url = `${import.meta.env.API_URL}/gallery?per_page=50`;
const res = await fetch(url);
const json = await res.json();
const data = GaleriasSchema.parse(json);
// console.log(data);
---

<div class="columns-1 md:columns-2 lg:columns-3 gap-5 my-8 space-y-5">
  {data.map((post) => <PostCard post={post} />)}
</div>
