---
import { DirectusHotNewsResponseSchema } from '@/types';
const newURL = `${import.meta.env.API_ITEMS}/hot_news`;
const newResponse = await fetch(newURL);
const newJson = await newResponse.json();
const newData = DirectusHotNewsResponseSchema.parse(newJson);
const { data: dataItems } = newData;
// console.log(dataItems);
---

<!----------------------- Ticker de Noticias Rápidas ----------------------->
<div
  class="mt-0 md:mt-20 bg-neon-yellow text-dark py-2 border-b-4 border-neon-yellow overflow-hidden font-mono font-bold text-lg flex items-center slider"
  style={`--width: 600px; --height: 50px; --quantity: ${dataItems.length}; `}
>
  <div class="list">
    {
      dataItems.map(
        (item) =>
          item.status === 'published' && (
            <div class="item" style={`--position: ${item.id}`}>
              <a class="flex flex-row" href={item.article_url} target="_blank">
                <span class="material-symbols-outlined mr-2">{item.icon}</span>
                <p>
                  {item.title}
                  <span>{item.subtitle}</span>
                </p>
              </a>
            </div>
          )
      )
    }
  </div>
</div>
