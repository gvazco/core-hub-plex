---
import { NewsInformeArraySchema } from '@/types';
const url = `${import.meta.env.API_URL}/news`;
const response = await fetch(url);
const json = await response.json();
const data = NewsInformeArraySchema.parse(json);
// console.log(data);
---

<!-- Ticker de Noticias Rápidas -->
<div
  class="mt-0 md:mt-20 bg-neon-yellow text-dark py-2 border-b-4 border-neon-yellow overflow-hidden font-mono font-bold text-lg flex items-center"
>
  <div class="animate-scroll">
    {
      data.map((item) => (
        <a
          href={item.acf.url}
          target="_blank"
          class="inline-flex items-center mx-4"
        >
          <span class="mx-4 uppercase">
            {item.title.rendered}
            {item.acf.informe}
          </span>
        </a>
      ))
    }
  </div>
</div>
