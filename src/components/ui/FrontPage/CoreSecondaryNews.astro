---
import AdvertisingSpace from '@/components/ui/FrontPage/AdvertisingSpace.astro';
import { Picture } from 'astro:assets';
import { formatDate } from '@/helpers';
import { InicioSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=inicio`;
const response = await fetch(url);
const json = await response.json();
const data = InicioSchema.parse(json[0]);
const secundarias = data.acf.secundarias;

// console.log(secundarias);
---

<!-- Grid de Noticias Secundarias -->
<section class="max-w-7xl px-2 mx-auto mt-10 mb-20">
  <h2
    class="text-3xl md:text-5xl font-black uppercase text-white mb-12 flex items-center gap-4"
  >
    <span class="w-8 h-8 bg-neon-pink inline-block neo-shadow-cyan"></span>
    MÁS NOTICIAS
    <span
      class="flex-grow h-2 bg-gradient-to-r from-neon-pink via-neon-cyan to-neon-green"
    ></span>
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
    <!-- Card 1 -->
    <article
      class="bg-dark neo-border-yellow p-5 neo-shadow-yellow neo-hover-yellow transition-neo flex flex-col group"
    >
      <a href={secundarias.izquierda.slug}>
        {
          secundarias.izquierda.imagen && (
            <Picture
              src={secundarias.izquierda.imagen}
              alt={secundarias.izquierda.titulo || 'Imagen Destacada'}
              width={600}
              height={600}
              formats={['avif', 'webp']}
              class="h-48 w-full object-cover border-b-4 border-neon-yellow mb-4 grayscale group-hover:grayscale-0 transition-all"
            />
          )
        }
        <span class="text-neon-yellow font-mono text-sm mb-2 font-bold"
          >{secundarias.izquierda.categoria}</span
        >
        <h3
          class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-yellow transition-colors"
        >
          {secundarias.izquierda.titulo}
        </h3>
        <a
          href={secundarias.izquierda.slug}
          class="text-white hover:text-neon-yellow font-mono font-bold flex justify-between items-center mt-auto border-t-2 border-gray-800 pt-4"
        >
          <span>LEER MÁS</span>
          <span class="text-xl">→</span>
        </a>
      </a>
    </article>

    <!-- Card 2 -->
    <article
      class="bg-dark neo-border-cyan p-5 neo-shadow-cyan neo-hover-cyan transition-neo flex flex-col group"
    >
      <a href={secundarias.centro.slug}>
        {
          secundarias.centro.imagen && (
            <Picture
              src={secundarias.centro.imagen}
              alt={secundarias.centro.titulo || 'Imagen Destacada'}
              width={600}
              height={600}
              formats={['avif', 'webp']}
              class="h-48 w-full object-cover border-b-4 border-neon-cyan mb-4 grayscale group-hover:grayscale-0 transition-all"
            />
          )
        }
        <span class="text-neon-cyan font-mono text-sm mb-2 font-bold"
          >{secundarias.centro.categoria}</span
        >
        <h3
          class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-cyan transition-colors"
        >
          {secundarias.centro.titulo}
        </h3>
        <a
          href={secundarias.centro.slug}
          class="text-white hover:text-neon-cyan font-mono font-bold flex justify-between items-center mt-auto border-t-2 border-gray-800 pt-4"
        >
          <span>LEER MÁS</span>
          <span class="text-xl">→</span>
        </a>
      </a>
    </article>

    <!-- Card 3 -->
    <article
      class="bg-dark neo-border-pink p-5 neo-shadow-pink neo-hover-pink transition-neo flex flex-col group"
    >
      <a href={secundarias.derecha.slug}>
        {
          secundarias.derecha.imagen && (
            <Picture
              src={secundarias.derecha.imagen}
              alt={secundarias.derecha.titulo || 'Imagen Destacada'}
              width={600}
              height={600}
              formats={['avif', 'webp']}
              class="h-48 w-full object-cover border-b-4 border-neon-cyan mb-4 grayscale group-hover:grayscale-0 transition-all"
            />
          )
        }
        <span class="text-neon-pink font-mono text-sm mb-2 font-bold"
          >{secundarias.derecha.categoria}</span
        >
        <h3
          class="text-2xl font-bold uppercase mb-4 flex-grow group-hover:text-neon-pink transition-colors"
        >
          {secundarias.derecha.titulo}
        </h3>
        <a
          href={secundarias.derecha.slug}
          class="text-white hover:text-neon-pink font-mono font-bold flex justify-between items-center mt-auto border-t-2 border-gray-800 pt-4"
        >
          <span>ESCUCHAR AHORA</span>
          <span class="text-xl">▶</span>
        </a>
      </a>
    </article>
  </div>
</section>
