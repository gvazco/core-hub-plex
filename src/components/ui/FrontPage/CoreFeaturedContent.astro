---
import AdvertisingSpace from '@/components/ui/FrontPage/AdvertisingSpace.astro';
import { Picture } from 'astro:assets';
import { formatDate } from '@/helpers';
import { InicioSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=inicio`;
const response = await fetch(url);
const json = await response.json();
const data = InicioSchema.parse(json[0]);
const titular = data.acf.titular;
const columna = data.acf.columna;
// console.log(data);
---

<!-- Contenido Principal -->
<section
  class="max-w-7xl px-6 md:px-0 mx-auto mt-10 grid grid-cols-1 lg:grid-cols-12 gap-12"
>
  <!-- Artículo Principal (Hero) -->
  <article
    class="lg:col-span-8 bg-dark p-6 neo-border-green neo-shadow-green neo-hover-green transition-neo relative group cursor-pointer flex flex-col justify-between"
  >
    <a href={titular.slug} target="_blank">
      <div
        class="uppercase absolute top-0 right-0 bg-neon-green text-dark font-mono font-bold px-4 py-2 text-xl transform translate-x-4 -translate-y-4 neo-border-green shadow-lg z-10"
      >
        {titular.epigrafe}
      </div>

      {
        data?.featured_images?.medium_large?.url && (
          <Picture
            src={
              data?.featured_images?.large?.url ||
              data?.featured_images?.medium_large?.url
            }
            alt={titular.titulo || 'Imagen Destacada'}
            width={data?.featured_images?.medium_large?.width || 600}
            height={data?.featured_images?.medium_large?.height || 600}
            formats={['avif', 'webp']}
            class="w-full h-[400px] object-cover border-4 border-neon-green mb-6 grayscale group-hover:grayscale-0 transition-all duration-500"
          />
        )
      }

      <h1
        class="text-2xl md:text-6xl font-extrabold uppercase leading-none mb-6 text-white group-hover:text-neon-green transition-colors"
      >
        {titular.titulo}
      </h1>
      <h3
        class="text-2xl font-bold text-neon-yellow uppercase leading-tight mb-4"
      >
        {titular.subtitulo}
      </h3>
      <p class="text-xl text-gray-400 font-mono mb-8 line-clamp-3">
        {titular.resumen}
      </p>
      <div
        class="flex flex-col md:flex-row md:justify-between items-center font-mono mt-auto border-t-4 border-neon-green pt-4"
      >
        <div class="mb-3 md:mb-0">
          <span
            class="bg-dark border-2 text-neon-green border-neon-green px-4 py-1 font-bold"
            >{titular.categoria}</span
          >
          <span
            class="bg-dark border-2 text-neon-green border-neon-green px-4 py-1 font-bold"
            >{titular.etiqueta}</span
          >
        </div>
        <span class="text-center">{formatDate(data.date)}</span>
      </div>
    </a>
  </article>

  <!-- Barra Lateral de Noticias -->
  <aside class="lg:col-span-4 flex flex-col gap-8">
    <article
      class="bg-neon-cyan text-dark p-6 border-4 border-neon-cyan neo-shadow-pink neo-hover-pink transition-neo cursor-pointer"
    >
      <a href={columna.impacto.slug} target="_blank">
        <span
          class="bg-dark text-neon-cyan font-mono px-3 py-1 text-sm font-bold border-2 border-dark mb-4 inline-block"
          >{columna.impacto.categoria}</span
        >
        <h2
          class="text-3xl text-neon-green font-bold uppercase leading-tight mb-4 text-dark mix-blend-exclusion"
        >
          {columna.impacto.titulo}
        </h2>
        <p class="font-mono text-dark opacity-90 font-bold mb-4 line-clamp-3">
          {columna.impacto.resumen}
        </p>
      </a>
    </article>

    <article
      class="bg-dark text-white p-6 neo-border-pink neo-shadow-cyan neo-hover-cyan transition-neo cursor-pointer"
    >
      <span
        class="bg-neon-pink text-dark font-mono px-3 py-1 text-sm font-bold mb-4 inline-block"
        >{columna.fondo.categoria}</span
      >
      <h2
        class="text-3xl font-bold uppercase leading-tight mb-4 group-hover:text-neon-pink transition-colors"
      >
        {columna.fondo.titulo}
      </h2>
      <div class="uppercase font-mono text-gray-400 text-sm font-bold">
        POR: {columna.fondo.autor} /// {columna.fondo.fecha}
      </div>
    </article>

    <!-- Advertising Space -->
    <AdvertisingSpace />
  </aside>
</section>
