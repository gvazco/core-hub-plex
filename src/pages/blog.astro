---
import CoreLayout from '@/layouts/CoreLayout.astro';
import BlogPosts from '@/components/blog/BlogPosts.astro';
import PostCategories from '@/components/ui/Taxonomies/PostCategories.astro';
import { DirectusBlogPageResponseSchema } from '@/types';
const newUrl = `${import.meta.env.API_ITEMS}/pages?filter[slug][_eq]=blog`;
const response = await fetch(newUrl);
const json = await response.json();
const data = DirectusBlogPageResponseSchema.parse(json);
const { data: blogPage } = data;
const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;
---

<CoreLayout
  title="Blog"
  subtitle={blogPage[0]?.subtitle || 'Nuestro blog'}
  bgImage={`${publicAssetsUrl}/${blogPage[0]?.cover_image}`}
>
  <PostCategories />
  <BlogPosts />
</CoreLayout>
