---
import CoreLayout from '@/layouts/CoreLayout.astro';
import BlogPosts from '@/components/blog/BlogPosts.astro';
import PostCategories from '@/components/ui/Taxonomies/PostCategories.astro';
import { BaseWPSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=blog`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
// console.log(data);
---

<CoreLayout
  title="Blog"
  subtitle={data?.acf?.subtitle || 'Nuestro blog'}
  bgImage={data?.featured_images?.full?.url || ''}
>
  <PostCategories />
  <BlogPosts />
</CoreLayout>
