---
import CoreLayout from '@/layouts/CoreLayout.astro';
import GalleryCategories from '@/components/ui/Taxonomies/GalleryCategories.astro';
import { DirectusGalleriesPageResponseSchema } from '@/types';
import SwiperGalleryWrapper from '@/components/galleries/SwiperGalleryWrapper.astro';
const newUrl = `${import.meta.env.API_ITEMS}/pages?filter[slug][_eq]=galerias`;
const newResponse = await fetch(newUrl);
const newJson = await newResponse.json();
const newData = DirectusGalleriesPageResponseSchema.parse(newJson);
const { data: galleriesPage } = newData;
---

<CoreLayout
  title={galleriesPage[0]?.title || 'Galerías'}
  subtitle={galleriesPage[0]?.subtitle}
  bgImage={`${import.meta.env.PUBLIC_ASSETS}/${galleriesPage[0]?.cover_image}`}
>
  <GalleryCategories />
  <SwiperGalleryWrapper />
</CoreLayout>
