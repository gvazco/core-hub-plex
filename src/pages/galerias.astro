---
import Layout from '@/layouts/CoreLayout.astro';
import GalleryPosts from '@/components/galleries/GalleryPosts.astro';
import GalleryCategories from '@/components/ui/GalleryCategories.astro';
import { BaseWPSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=galerias`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
console.log(data);
---

<Layout
  title="Galería"
  subtitle={data?.acf?.subtitle || 'Nuestra galería de imágenes'}
  bgImage={data?.featured_images?.full?.url || ''}
>
  <div
    class="text-lg sm:text-xl space-y-3 mt-2 sm:mt-10 lg:mt-0 line-clamp-5 md:line-clamp-none"
    set:html={data.content.rendered}
  />

  <GalleryCategories />
  <GalleryPosts />
</Layout>
