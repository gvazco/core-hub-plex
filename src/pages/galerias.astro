---
import CoreLayout from '@/layouts/CoreLayout.astro';
import GalleryCategories from '@/components/ui/Taxonomies/GalleryCategories.astro';
import { BaseWPSchema } from '@/types';
import SwiperGalleryWrapper from '@/components/galleries/SwiperGalleryWrapper.astro';
const url = `${import.meta.env.API_URL}/pages?slug=galerias`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
// console.log(data);
---

<CoreLayout
  title="Galería"
  subtitle={data?.acf?.subtitle || 'Nuestra galería de imágenes'}
  bgImage={data?.featured_images?.full?.url || ''}
>
  <GalleryCategories />
  <SwiperGalleryWrapper />
  <!-- <GalleryPosts /> -->
</CoreLayout>
