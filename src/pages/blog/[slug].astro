---
import CoreLayout from '@/layouts/CoreLayout.astro';
import { Picture } from 'astro:assets';
import { PostSchema, DirectusArticlesCollectionSchema } from '@/types';
import PostMeta from '@/components/blog/PostMeta.astro';
import PostCategories from '@/components/blog/PostCategories.astro';
import PostTags from '@/components/blog/PostTags.astro';
import GalleryBanner from '@/components/blog/GalleryBanner.astro';

export const prerender = false;
const { slug } = Astro.params;
const newsRes = await fetch(
  `${import.meta.env.API_ITEMS}/articles?filter[slug][_eq]=${slug}&fields=*,article_category.*,article_tags.*,author.*`
);
const newJson = await newsRes.json();
const newPost = DirectusArticlesCollectionSchema.safeParse(newJson.data[0]);

if (!newPost.success) return Astro.redirect('/404');
const {
  title,
  subtitle,
  seo_title,
  seo_description,
  status,
  excerpt,
  cover_image,
  date_created,
  markdown_disabled,
  article_category,
  article_tags,
  gallery_slug,
  gallery_enabled,
  author,
  video_enabled,
  video_cover,
} = newPost.data;
const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;
// console.log(newPost.data);
---

<CoreLayout title={title} bgImage={`${publicAssetsUrl}/${cover_image}`}>
  {
    video_cover && video_enabled ? (
      <div class="aspect-video">
        <iframe
          src={video_cover}
          title={title}
          allowfullscreen
          class="w-full h-full"
        />
      </div>
    ) : (
      cover_image && (
        <Picture
          src={`${publicAssetsUrl}/${cover_image}`}
          alt={title}
          width={800}
          height={600}
          formats={['avif', 'webp']}
          class="w-full"
        />
      )
    )
  }
  <article
    class="relative top-[-60px] md:top-[-100px] lg:top-[-130px] bg-dark-transparent space-y-5 p-5 max-w-5xl mx-auto"
  >
    <h1
      class="text-xl md:text-3xl lg:text-4xl font-black text-black dark:text-white uppercase tracking-tight"
    >
      {title}
    </h1>
    <PostMeta
      date={date_created}
      author={author ? author?.name : ''}
      slug={author ? author?.slug : ''}
    />
    <PostCategories name={article_category.name} slug={article_category.slug} />
    <PostTags name={article_tags?.name} slug={article_tags?.slug} />

    <div set:html={markdown_disabled} class="text-lg space-y-3 mt-5" />

    {
      gallery_slug && gallery_enabled ? (
        <div class="aspect-gallery-banner">
          <div class="mx-auto max-w-7x">
            <div class="relative isolate overflow-clip bg-gray-900 px-6 pt-16 shadow-2xl sm:rounded-3xl sm:px-16 md:pt-24 lg:flex lg:gap-x-20 lg:px-24 lg:pt-0">
              <div
                aria-hidden="true"
                class="absolute right-0 top-0 -z-10 aspect-square w-full max-w-3xl translate-x-3/4 rounded-full bg-pink-500/60 blur-[10rem] lg:-top-[40rem] lg:left-1/2 lg:-translate-x-1/2"
              />
              <div class="mx-auto max-w-md text-center lg:mx-0 lg:flex-auto lg:py-24 lg:text-start">
                <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
                  Want to partner with design experts in SaaS?
                </h2>
                <p class="mt-6 text-base text-gray-300">
                  We're excited to talk to you about your project requirements
                  and business goals.
                </p>
                <div class="mt-10 flex items-center justify-center gap-x-6 lg:justify-start">
                  <a
                    href="#"
                    class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-gray-900 hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
                  >
                    Schedule a call
                  </a>
                  <a
                    href="#"
                    class="text-sm font-semibold leading-6 text-white"
                  >
                    Send an email
                  </a>
                </div>
              </div>
              <div class="relative mt-16 h-80 lg:mt-8 lg:h-auto">
                <img
                  width="1920"
                  height="1139"
                  class="absolute left-0 top-0 w-[58rem] max-w-none rounded-2xl bg-white/5 ring-1 ring-white/10 lg:top-14"
                  src="https://htmlwind.com/assets/images/dark-dashboard-screenshot.webp"
                  alt="dashboard screenshot"
                />
              </div>
            </div>
          </div>
        </div>
      ) : (
        ''
      )
    }

    {
      gallery_slug && gallery_enabled ? (
        <GalleryBanner gallerySlug={gallery_slug} />
      ) : (
        ''
      )
    }
  </article>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const banner = document.querySelector('[data-gallery-banner]');
      const closeButton = document.querySelector('[data-gallery-close]');
      if (!banner || !closeButton) return;

      const hideBanner = () => {
        banner.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => banner.remove(), 200);
      };

      closeButton.addEventListener('click', hideBanner);
      closeButton.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          hideBanner();
        }
      });
    });
  </script>
</CoreLayout>
