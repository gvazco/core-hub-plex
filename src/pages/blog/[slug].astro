---
import CoreLayout from '@/layouts/CoreLayout.astro';
import { Picture } from 'astro:assets';
import { DirectusArticlesCollectionSchema } from '@/types';
import PostMeta from '@/components/blog/PostMeta.astro';
import PostCategories from '@/components/blog/PostCategories.astro';
import PostTags from '@/components/blog/PostTags.astro';
import GalleryBanner from '@/components/blog/GalleryBanner.astro';

export const prerender = false;
const { slug } = Astro.params;
const newsRes = await fetch(
  `${import.meta.env.API_ITEMS}/articles?filter[slug][_eq]=${slug}&fields=*,article_category.*,article_tags.*,author.*`
);
const newJson = await newsRes.json();
const newPost = DirectusArticlesCollectionSchema.safeParse(newJson.data[0]);
// console.log(newPost);

if (!newPost.success) return Astro.redirect('/404');
const {
  title,
  subtitle,
  seo_title,
  seo_description,
  status,
  excerpt,
  cover_audio,
  cover_image,
  date_created,
  markdown_disabled,
  article_category,
  article_tags,
  gallery_slug,
  gallery_enabled,
  banner_description,
  banner_image,
  author,
  video_enabled,
  video_cover,
} = newPost.data;
const publicAssetsUrl = import.meta.env.PUBLIC_ASSETS;
// console.log(newPost.data);
---

<CoreLayout title={title} bgImage={`${publicAssetsUrl}/${cover_image}`}>
  {
    video_cover && video_enabled ? (
      <div class="aspect-video">
        <iframe
          src={video_cover}
          title={title}
          allowfullscreen
          class="w-full h-full"
        />
      </div>
    ) : (
      cover_image && (
        <Picture
          class="max-w-5xl w-full h-auto object-cover"
          src={`${publicAssetsUrl}/${cover_image}`}
          alt={title}
          width={800}
          height={400}
          formats={['avif', 'webp']}
          class="w-full"
        />
      )
    )
  }
  <article
    class="relative top-[-60px] md:top-[-100px] lg:top-[-130px] bg-dark-transparent space-y-5 p-5 max-w-5xl mx-auto"
  >
    <h1
      class="text-xl md:text-3xl lg:text-4xl font-black text-black dark:text-white uppercase tracking-tight"
    >
      {title}
    </h1>
    {
      subtitle && (
        <h2 class="text-lg md:text-2xl text-gray-700 dark:text-gray-300">
          {subtitle}
        </h2>
      )
    }

    <PostMeta
      date={date_created}
      author={author ? author?.name : ''}
      slug={author ? author?.slug : ''}
    />
    <PostCategories name={article_category.name} slug={article_category.slug} />
    <PostTags name={article_tags?.name} slug={article_tags?.slug} />

    {
      cover_audio && (
        <div class="audio-container w-full">
          <span class="audio-title">Escuchar artículo</span>
          <audio controls preload="metadata" class="w-full">
            <source
              src={`${publicAssetsUrl}/${cover_audio}`}
              type="audio/mpeg"
            />
          </audio>
        </div>
      )
    }

    <div
      set:html={markdown_disabled}
      id="gallery"
      class="main-content text-xl space-y-3 mt-5"
    />

    {
      gallery_slug && gallery_enabled ? (
        <GalleryBanner gallerySlug={gallery_slug} />
      ) : (
        ''
      )
    }
  </article>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const banner = document.querySelector('[data-gallery-banner]');
      const closeButton = document.querySelector('[data-gallery-close]');
      if (!banner || !closeButton) return;

      const hideBanner = () => {
        banner.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => banner.remove(), 200);
      };

      closeButton.addEventListener('click', hideBanner);
      closeButton.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          hideBanner();
        }
      });
    });
  </script>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });
    lightbox.on('uiRegister', function () {
      if (lightbox.pswp?.ui) {
        lightbox.pswp.ui.registerElement({
          name: 'custom-caption',
          order: 9,
          isButton: false,
          appendTo: 'root',
          html: 'Caption text',
          onInit: (el, pswp) => {
            lightbox.pswp?.on('change', () => {
              const currSlideElement = lightbox.pswp?.currSlide?.data?.element;
              let captionHTML = '';
              if (currSlideElement) {
                const hiddenCaption = currSlideElement.querySelector(
                  '.hidden-caption-content'
                );
                if (hiddenCaption) {
                  // get caption from element with class hidden-caption-content
                  captionHTML = hiddenCaption.innerHTML;
                } else {
                  // get caption from alt attribute
                  captionHTML =
                    currSlideElement
                      .querySelector('img')
                      ?.getAttribute('alt') ?? '';
                }
              }
              el.innerHTML = captionHTML || '';
            });
          },
        });
      }
    });
    lightbox.init();
    document.addEventListener('astro:after-swap', function () {
      lightbox.init();
    });
  </script>
</CoreLayout>
